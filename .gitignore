# Dependencies
**/node_modules/

# Python virtual environments
**/venv/
**/.venv/

# Cairo/Starknet build & cache
/target/
**/target/
/.snfoundry_cache/
**/.snfoundry_cache/
/.artifacts/

# Logs and runtime output
*.log
**/*.log
*.pyc
**/*.pyc
__pycache__/
**/__pycache__/

# Local environment files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Sensitive/local frontend runtime state
/semaphore-frontend/data/history.json
/semaphore-frontend/data/relay_idempotency.json
/semaphore-frontend/data/drift_report.latest.json
/semaphore-frontend/data/indexer_read_model.latest.json
/semaphore-frontend/data/*.tmp
/semaphore-frontend/data/*.json.*.tmp
/semaphore-frontend/oz_keys.json

# Local screenshots and temp assets
/semaphore-frontend/screenshots/
/scripts/.tmp_point_31/

# Local wallet / keystore / secret material
*.pem
*.key
*.keystore
*.keystore.json
*.password
**/*.pem
**/*.key
**/*.keystore
**/*.keystore.json
**/*.password
.starkli-wallets/
**/.starkli-wallets/

# Keep only README markdowns tracked by default
*.md
**/*.md
!README.md
!**/README.md

# OS/editor junk
.DS_Store
Thumbs.db
*.Zone.Identifier
.vscode/
.idea/
