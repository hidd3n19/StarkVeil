# Local frontend/backend server environment
HOST=127.0.0.1
PORT=8787
CIRCUIT_DEPTH=20

# Phase 1 migration flags
MODE=offchain
ONCHAIN_WRITE_ENABLED=false
ONCHAIN_READ_PREFERRED=false

# Optional Phase 2 relay settings
CONTRACT_RELAY_MODE=mock
ONCHAIN_RELAY_MAX_RETRIES=3

# Phase 4 indexer refresh interval (ms)
INDEXER_POLL_INTERVAL_MS=2000

# Optional deploy/test account settings
STARKNET_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
ARGENT_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS
ARGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
